msgid "Твердження користувача."
msgstr "The user's claim to verify."

#: of services.ai_service.call_base_gpt:11
msgid "Рядки з офіційних та перевірених сайтів (A+, A, B списки)."
msgstr "Strings from official and verified sites (A+, A, B whitelists)."

#: of services.ai_service.call_base_gpt:13
msgid "Інші джерела з Інтернету."
msgstr "Other general internet sources."

#: of services.ai_service.call_base_gpt:15
msgid "Обрана базова модель OpenAI (наприклад `gpt-4o`)."
msgstr "Selected base OpenAI model (e.g. `gpt-4o`)."

#: of services.ai_service.call_base_gpt:17
msgid "ID користувача для статистики."
msgstr "User ID for usage statistics."

