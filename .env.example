# ================================================================
# Telegram
# ================================================================
# Отримати у @BotFather: https://t.me/BotFather
BOT_TOKEN=your_telegram_bot_token

# ================================================================
# AI провайдери
# ================================================================
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# Together AI: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=your_together_api_key

# Perplexity AI: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key

# ================================================================
# Пошук (Google через Serper)
# ================================================================
# Serper: https://serper.dev/api-key
SERPER_API_KEY=your_serper_api_key

# ================================================================
# Назви моделей
# ================================================================
MODEL_NAME=gpt-4o-mini
# Якщо є fine-tuned модель — вставте її ID:
MODEL_GPT_4_1_mini=ft:gpt-4o-mini:your-org:your-model-id
MODEL_TOGETHER_FT=meta-llama/Llama-3.1-8B-Instruct-Turbo

# ================================================================
# Адміністратор бота (Telegram user_id)
# ================================================================
# Дізнатись свій user_id: https://t.me/userinfobot
ADMIN_ID=your_telegram_user_id
